{% extends 'threeColumns.html.twig' %}
{% import 'macros.html.twig' as formRender %}

{% block content %}
    {% set translationPrefix, isTextInput, contributors, everyday, burdensRisksController = 'projectdetails.pages.burdensRisks.', textInputCon is not same as '', content.burdensRisksContributors, content.burdensEveryday, 'Projectdetails--burdensRisks' %}
    {% set isContributorsSelected, everydayDiv, everydayValue, textHintParams = contributors.vars.value is same as '0', 'burdensEverydayDiv', everyday.vars.value, {'burdens': checkboxTypes['burdens']|slice(1), 'risks': checkboxTypes['risks']|slice(1)} %}
    {# burdens, risks, and burdens/risks for contributors #}
    <div {{ stimulus_controller(burdensRisksController,{
            'burdens': checkboxTypes['burdens']|slice(1),
            'risks': checkboxTypes['risks']|slice(1)
    }) }}>
        {% for type in ['burdens','risks','burdensRisksContributors'] %}
            {% set isBurdens, isBurdensRisks, checkboxes = type is same as 'burdens', type is not same as 'burdensRisksContributors', checkboxTypes[type] ?? [] %}
            {% set typePrefix, checkboxesWoNo, typeParam, hasBurdensNoDescription = translationPrefix~type~'.', checkboxes|slice(1), {'type': type}, isBurdens and content.burdensNoDescription is defined %}
            {% set anySelected, noID, descriptionDiv, compensationDiv = getAnySelected(content,checkboxesWoNo)[1], 'no'~(type|capitalize), type~'DescriptionDiv', type~'CompensationDiv' %}
            {% set visibility = isBurdensRisks ? anySelected : isContributorsSelected %}
            <div {% if not isBurdens %} class="mt-8" {% endif %} id="{{ type~'Type' }}">
                {{ formRender.addHeading(typePrefix~'title',{'headingHint': [[typePrefix~'hints.headingHint']]}) }}
                {% if isBurdensRisks %}
                    <div class="MetaData-Widget mt-2"
                            {{ stimulus_action('base','setMultiCheckbox','change',{
                                'single': noID,
                                'multiCheck': checkboxesWoNo})|
                            stimulus_action('base','setVisibility','change',{
                                'multi': [[checkboxesWoNo,[descriptionDiv]|merge([not isBurdens ? compensationDiv : everydayDiv])]]|merge(hasBurdensNoDescription ? [['noBurdens','burdensNoDescriptionDiv']] : []),
                                'setOr': [0]})|
                            stimulus_action(burdensRisksController,'setTextInputHint','change',textHintParams)}}>
                        {{ formRender.addCheckboxGroup(content,checkboxes,{'icons': iconArrays[type]}|merge(anySelected or content[noID].vars.checked ? {'targets': anySelected ? [noID] : checkboxesWoNo} : {})) }}
                    </div>
                {% else %}
                    <div class="mt-2" {{ stimulus_action('base','setVisibility','change',{'values': [['0',[descriptionDiv,compensationDiv]]]}) }}>{{ formRender.renderButtons(contributors,noHeading) }}</div>
                {% endif %}
                {# description #}
                {{ formRender.addTextfield(content[type~'Description'],fontNormal|merge({
                    'visibility': visibility,
                    'hint': translationPrefix~'textHint',
                    'textHintParams': typeParam,
                    'attributes': textHeightLong})) }}
                {# description of no burdens #}
                {% if hasBurdensNoDescription %}
                    {{ formRender.addTextfield(content.burdensNoDescription,fontNormal|merge({'visibility': content.noBurdens.vars.checked})) }}
                {% endif %}
                {# burdens everyday #}
                {% if isBurdens %}
                    {% set visibility = everydayValue is same as '0' %}
                    <div class="mt-8" id="{{ everydayDiv }}" style="{{ boolToDisplay(anySelected) }}" {{ stimulus_action(burdensRisksController,'setTextInputHint','change',textHintParams) }}>
                        {{ formRender.renderButtons(everyday,{
                            'stimVisible': {'values': [['0',compensationDiv]]},
                            'contTarget': ['burdensEveryday0',burdensRisksController,'burdensEverydayYes']}) }}
                {% endif %}
                {# compensation #}
                <div class="mt-8" id="{{ compensationDiv }}" style="{{ boolToDisplay(visibility) }}">
                    {% set compensation, compensationPrefix = content[type~'Compensation'], translationPrefix~'compensation.textHints.' %}
                    {% set value = compensation.vars.value %}
                    {% set noSelection, yesTrans, noTrans = value is same as '', (compensationPrefix~'yes')|trans(typeParam), (compensationPrefix~'no')|trans %}
                    {{ formRender.renderButtons(compensation,{
                        'text': [content[type~'CompensationDescription'],fontNormal|merge({'hint': noSelection ? 'multiple.choiceTextHint' : (value is same as '0' ? yesTrans : noTrans), 'attributes': textHeightLong|merge({'disabled': noSelection})})],
                        'stim': ['base','setWidgetByValue',{'widgetValue': ['',type~'CompensationDescription',{'0': yesTrans, '1': noTrans}]}]}) }}
                </div>
                {% if isBurdens %}
                    </div> {# closing tag of burdens everyday #}
                {% endif %}
                {% if isBurdensRisks and isTextInput %}
                    <div class="mt-8">{{ formRender.addHint(textInputCon,{
                            'visible': not (getAnySelected(content,checkboxTypes['burdens']|slice(1))[1] and everydayValue is same as '1' or getAnySelected(content,checkboxTypes['risks']|slice(1))[1]),
                            'remove': true,
                            'target': [burdensRisksController,'textInput']}) }}</div>
                {% endif %}
            </div>
        {% endfor %}
        {# finding #}
        {% set finding, addresseeParams, hintDiv, tempPrefix = content.finding, {'addressee': addresseeType}, 'findingHintDiv', translationPrefix~'finding.' %}
        {% set findingValue, informing, findingDiv, inputDiv = finding.vars.value, content.informing, 'findingDiv', 'inputDiv' %}
        {% set isFinding, isTextInput, isPre = findingValue is same as '0', textInputFinding is not same as '', information is same as 'pre' %}
        <div class="mt-8" id="finding">
            {{ formRender.renderButtons(finding,{'text': [content.description,fontNormal|merge({'visibility': isFinding, 'textHintParams': addresseeParams})], 'hint': [tempPrefix], 'stimVisible': {'values': [['0',['descriptionDiv',findingDiv]]]|merge(isTextInput ? [['1',inputDiv]] : [])}}) }}
            <div id="{{ findingDiv }}" style="{{ boolToDisplay(isFinding) }}">
                <div class="MetaData-Label mt-4">{{ form_label(informing,null,labelDummy) }}</div>
                <div class="mt-2">{{ formRender.renderButtons(informing,noHeading|
                        merge({'hint': ['projectdetails.pages.burdensRisks.finding.informing.',addresseeParams],
                        'labelParams': {'addressee': addresseeString}})|
                        merge(isPre ? {'stimVisible': {'values': [['always',hintDiv]]}} : {})) }}</div>
                {% if isPre %}
                    <div class="mt-4">
                        {{ formRender.addHint(tempPrefix~'informing.hint',{'id': hintDiv, 'visible': informing.vars.value is same as 'always', 'params': routeIDsParam}) }}
                    </div>
                {% endif %}
            </div>
            {% if isTextInput %}
                {{ formRender.addHint(textInputFinding,{'id': inputDiv, 'visible': findingValue is same as '1', 'remove': true}) }}
            {% endif %}
        </div>
        {# feedback #}
        {% if content.feedback is defined %}
            {% set feedback = content.feedback %}
            {{ formRender.renderButtons(feedback,{'text': [content.feedbackDescription,fontNormal|merge({'visibility': feedback.vars.value is same as '0'})], 'hint': [translationPrefix~'feedback.'], 'stimVisible': {'values': [['0','feedbackDescriptionDiv']]}, 'addDiv': ['feedback']}) }}
        {% endif %}
        {{ formRender.addSubmitButtons() }}
    </div> {# entire form #}
{% endblock %}

{% block preview %}
    {{ formRender.addPreview([studyID,groupID,measureID]) }}
{% endblock %}