{% extends 'threeColumns.html.twig' %}
{% import 'macros.html.twig' as formRender %}

{% block content %}
    {% set translationPrefix, informationParam, addresseeParamTextHint, ensureDiv = 'projectdetails.pages.consent.', {'type': information in ['pre',''] ? 'pre' : 'post'},{'textHintParams': {'addressee': addresseeType}}, 'voluntaryEnsure' %}
    {% set isVoluntaryYesDefined, inputDiv, isTextInput, labelParams = content.absence is defined, 'inputDiv', textInput is not same as '', {'addressee': addresseeString, 'participant': participantsString} %}
    <div>
        {# voluntary and consent #}
        {% for type in ['voluntary','consent'] %}
            {% set isNotParticipants, visible, isConsent, anyYes, typePrefix, description = content[type~'Participants'] is defined, false, type is same as 'consent', false, translationPrefix~type~'.', type~'Description' %}
            {% set isClosedDependent = not isConsent and isVoluntaryYesDefined %} {# if the options change, the values containing numbers might have to be updated as well #}
            <div {% if isConsent %} class="mt-8" {% endif %} id="{{ type }}">
                {{ formRender.addHeading(typePrefix~'title',{'params': headingParams}) }}
                {% for addressee in ['']|merge(isNotParticipants ? ['Participants'] : []) %}
                    {% set widget, otherDiv = content[type~addressee], 'consentOtherDiv'~addressee %}
                    {% set value, isAddresseePart = widget.vars.value, addressee is same as 'Participants'  %}
                    {% set visible, anyYes, optionNo = visible or value is same as 'no', anyYes or value is same as 'yes', type~'no' %}
                    {% if not (isConsent or isAddresseePart) %}
                        {{ formRender.addHint(typePrefix~'headingHint') }} {# not in renderButtons in case the addressee is added between heading and buttons #}
                    {% endif %}
                    {% if isNotParticipants %}
                        <div class="MetaData-Label {% if isAddresseePart %} mt-4 {% else %} mt-2 {% endif %}" id="{{ type~'Type'~addressee }}">{{ form_label(widget,null,labelDummy) }}</div>
                    {% endif %}
                    {{ formRender.renderButtons(widget,noHeading|merge({
                        'labelParams': (not isAddresseePart ? labelParams : labelParamsParticipants)|merge({'curAddressee': addressee}),
                        'stimVisible': {'multi': [[[optionNo]|merge(isNotParticipants ? [type~'Participantsno'] : []),description~'Div']]|merge(isConsent ? [[type~addressee~'other',otherDiv]]|merge(isTextInput ? [[optionNo,[],inputDiv]] : []) : (isClosedDependent ? [[['voluntaryyes']|merge(isNotParticipants ? ['voluntaryParticipantsyes'] : []),ensureDiv]]: [])), 'setOr': true, 'isGrid': true}})|
                         merge(isConsent ? {'icons': {('consent'~addressee~'other'): typePrefix~'hint'}} : {})) }}
                    {% if isConsent %}
                        <div id="{{ otherDiv }}" class="MetaData-Widget grid" style="{{ boolToDisplay(value is same as 'other',1) }}; width: 20rem; margin-left: 2rem; {% if not isAddresseePart %} grid-template-columns: auto min-content {% endif %}">
                            {{ form_widget(content['otherDescription'~addressee]) }}
                            {% if not isAddresseePart %}
                                {{ formRender.addPDFhint(['consent'],addresseeType)}}
                            {% endif %}
                        </div>
                        {% if not isAddresseePart and isTextInput %}
                            <div class="mt-4">{{ formRender.addHint(textInput,{'id': inputDiv, 'visible': content.consent.vars.value is not same as 'no', 'remove': true}) }}</div>
                        {% endif %}
                    {% endif %}
                {% endfor %}
                <div id="{{ type~'DescriptionDiv' }}" style="{{ boolToDisplay(visible) }}">
                    {{ formRender.addTextfield(content[description],addresseeParamTextHint|merge(fontNormal)|merge({'hint': typePrefix~'textHint'})) }}
                </div>
                {% if isClosedDependent %}
                    {% set tempPrefix = translationPrefix~'voluntary.voluntaryEnsure.' %}
                    <div class="mt-8" id="{{ ensureDiv }}" style="{{ boolToDisplay(anyYes) }}">
                        {{ formRender.addHeading(tempPrefix~'title',{'headingHint': [[tempPrefix~'headingHint']]}) }}
                        {{ formRender.addCheckboxGroup(content,ensureTypes,{'other': ensureTypesOther, 'icons': {'relatable': tempPrefix~'hint'}, 'addDiv': ['','','mt-2']}) }}
                    </div>
                {% endif %}
            </div>
        {% endfor %}
        {# terminate with disadvantages #}
        {% set terminateCons, terminateConsParticipation, transferParam = content.terminateCons, content.participation ?? '', {'transfer': [transferInfo,addresseeType]} %}
        {% set visibility, isInformation = fontNormal|merge({'visibility': terminateCons.vars.value is same as '1'}), terminateConsParticipation is not same as '' %}
        <div class="mt-8" id="terminateConsDiv">
            {{ formRender.renderButtons(terminateCons,{'text': [content.terminateConsDescription,visibility], 'stimVisible': {'values': [['1',['terminateConsDescriptionDiv']|merge(isInformation ? ['participationDiv'] : [])]]}, 'hint': [translationPrefix~'terminateCons.']}) }}
            {% if isInformation %}
                {{ formRender.addTextfield(terminateConsParticipation, visibility|merge(transferParam)|merge(addresseeParamTextHint)) }}
            {% endif %}
        </div>
        {# termination by participants #}
            {% if content.terminateParticipants is defined %}
            {% set terminate, description, other = content.terminateParticipants, content.terminateParticipantsText, 'terminateParticipantsOther' %}
            {{ formRender.renderButtons(terminate,{
                'text': [description,transferParam|merge(fontNormal)|merge({'visibility': terminate.vars.value is same as other})],
                'stimVisible': {'values': [[other,description.vars.name~'Div']]},
                'addDiv': ['terminateParticipants'],
                'labelParams': {'information': information}}) }}
        {% endif %}
        {# terminate criteria #}
        {% if content.terminateCriteria is defined %}
            <div class="mt-8" id="terminateCriteriaDiv">
                {{ formRender.addHeading(translationPrefix~'terminateCriteria.title') }}
                {{ formRender.addTextfield(content.terminateCriteria, {'noTopMargin': true}) }}
            </div>
        {% endif %}
        {{ formRender.addSubmitButtons() }}
    </div> {# entire form #}
{% endblock %}

{% block preview %}
    {{ formRender.addPreview([studyID,groupID,measureID]) }}
{% endblock %}