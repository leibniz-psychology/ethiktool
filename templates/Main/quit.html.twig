{% extends 'base.html.twig' %}
{% import 'macros.html.twig' as formRender %}

{% block body %}
    <div class="pb-5 grid">
        {{ include('components/header.html.twig',committeeParams|merge({'update': isUpdateTime})) }}
        <div class="border rounded-lg shadow-sm bg-mono-50 winWidth" style="height: fit-content; justify-self: center; max-width: 1600px">
            <div class="MetaData-Label mb-1">
                {{ 'quit'|trans|raw|nl2br }}
            </div>
        </div>
    </div>
    <footer id="page-footer" class="mt-auto">
        {{ render(path('app_footer')) }}
    </footer>
{% endblock %}